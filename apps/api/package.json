{
  "name": "@receptionist/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate --schema prisma/schema.prisma && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prisma:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.2.1",
    "@prisma/client": "^6.19.3",
    "@receptionist/shared": "0.1.0",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.58.5",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.2.2",
    "exceljs": "^4.4.0",
    "fastify": "^5.6.0",
    "googleapis": "^173.0.0",
    "pino": "^9.9.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prisma": "^6.19.3",
    "tsx": "^4.20.5",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  }
}
